# Local services
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shopagent
POSTGRES_USER=shopagent
POSTGRES_PASSWORD=shopagent

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shopagent_reviews
QDRANT_API_KEY=

# LLM provider
ANTHROPIC_API_KEY=sk-ant-your-key-here
SHOPAGENT_MODEL=claude-sonnet-4-6
SHOPAGENT_EVAL_MODEL=claude-sonnet-4-6

# Optional local Docker container override
SHOPAGENT_POSTGRES_CONTAINER=infra-postgres-1
